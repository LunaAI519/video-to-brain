# === 必填：Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === 可选：突破20MB限制（大视频下载）===
# 获取方法：https://my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# === 可选：AI 智能笔记 ===
# 支持任何 OpenAI 兼容的 API（OpenAI、Claude、本地 Ollama 等）
# 不配置 = 只做基础转录，不做AI分析
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 用 Ollama 本地模型（免费，不用API）:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3
# LLM_API_KEY=ollama

# 用 Claude:
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-3-haiku-20240307
# LLM_API_KEY=your_claude_key

# === 可选：Obsidian 笔记库路径 ===
# 默认: ~/Documents/notes
OBSIDIAN_VAULT=~/Documents/my-vault

# === 可选：访问控制 ===
# 限制谁可以使用 bot（Telegram user ID，逗号分隔）
# 留空 = 所有人都可以用（不推荐用于生产环境）
# 获取 user ID: 给 @userinfobot 发消息
ALLOWED_USERS=

# === 可选：频率限制 ===
# 每个用户每分钟最多处理几个视频（默认 5）
RATE_LIMIT=5
